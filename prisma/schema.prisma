generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Ad {
  id            String    @id @default(cuid())
  name          String    // Auto-generado: FECHA_CONCEPTO_ANGULO_FORMATO
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // === NOMENCLATURA (Identificación única) ===
  concept       String    // Mensaje central en 3-4 palabras (ej: "Ahorro de dinero")
  angleType     String    @default("fear")    // fear, desire, curiosity, offer, tutorial, testimonial
  angleDetail   String?                        // Texto del research (opcional)
  awareness     String    @default("unaware") // unaware, problem_aware, solution_aware, product_aware, most_aware
  format        String    // "static" | "video" | "ugc" | "carousel"
  funnelStage   String    // "cold" | "retargeting"
  product       String?   // Producto específico si vendes varios

  // === MÓDULO INTENCIÓN (Obligatorio) ===
  hypothesis    String    // "Creo que funcionará porque..."
  sourceType    String    @default("original") // "original" | "competitor" | "iteration"
  sourceUrl     String?   // URL si es de competencia
  referenceMediaUrl String? // Video/imagen de referencia subido

  // === ESTADO (Pipeline Kanban) ===
  status        String    @default("idea")
  // Estados: "idea" | "production" | "testing" | "analysis" | "completed"

  // === DEADLINE ===
  dueDate       DateTime? // Fecha limite para completar el ad

  // === DESARROLLO CREATIVO ===
  script        String?   // Guion del anuncio
  hook          String?   // Hook principal (primeros 3 segundos)
  cta           String?   // Call to action
  notes         String?   // Notas adicionales de desarrollo

  // === REGLA DE LOS 10 DÍAS ===
  testingStartedAt  DateTime?  // Cuando se movió a "testing"
  reviewDate        DateTime?  // testingStartedAt + 10 días (auto-calculado)
  testingBudget     Float?     // Presupuesto asignado al test
  isLocked          Boolean    @default(false) // True mientras está en testing
  lockDays          Int        @default(10)    // Días de bloqueo configurables

  // === MÉTRICAS (Ingreso manual) ===
  spend         Float?
  impressions   Int?
  clicks        Int?
  purchases     Int?
  revenue       Float?

  // === MÉTRICAS DE VIDEO ===
  videoViewThreeSeconds  Int?    // Vistas de 3 segundos
  videoViewThruplay      Int?    // Vistas completas (o 15 seg si video > 15 seg)
  // Hook Rate = videoViewThreeSeconds / impressions (< 20% = hook malo)
  // Hold Rate = videoViewThruplay / videoViewThreeSeconds (guion aburrido si bajo)

  // === POST-MORTEM (Análisis final) ===
  result        String?   // "winner" | "loser"
  diagnosis     String?   // "¿Por qué ganó/perdió?"
  action        String?   // "iterate" | "kill" | "scale"
  closedAt      DateTime?

  // === ETIQUETAS DE FALLO/ÉXITO (Para análisis cuantitativo) ===
  failReasons      String?   // JSON array: ["bad_hook", "boring_script"]
  successFactors   String?   // JSON array: ["high_contrast", "urgency"]

  // === EVALUACIÓN POR ELEMENTOS ===
  hookResult    String?   // "worked" | "failed" | null
  hookNote      String?   // El hook exacto que funciono/fallo
  avatarResult  String?   // "worked" | "failed" | null
  avatarNote    String?   // Descripcion del avatar/presentador
  scriptResult  String?   // "worked" | "failed" | null
  scriptNote    String?   // Parte del guion que destaco
  ctaResult     String?   // "worked" | "failed" | null
  ctaNote       String?   // El CTA exacto
  visualResult  String?   // "worked" | "failed" | null
  visualNote    String?   // Que elemento visual funciono/fallo
  audioResult   String?   // "worked" | "failed" | null
  audioNote     String?   // Que musica/sonido uso

  // === MEDIA ===
  thumbnailUrl  String?   // URL o path de la imagen/video

  // === RELACIONES ===
  learnings     Learning[]
  dailyMetrics  DailyMetric[]

  // Conexión con Avatar (a quién le habla este ad)
  avatarId      String?
  avatar        Avatar?  @relation(fields: [avatarId], references: [id], onDelete: SetNull)

  // Conexión con Sub-Avatar (momento/estado específico)
  subAvatarId   String?
  subAvatar     SubAvatar? @relation(fields: [subAvatarId], references: [id], onDelete: SetNull)
}

model Learning {
  id        String   @id @default(cuid())
  content   String   // La lección: "El fondo negro funcionó mejor"
  type      String   @default("insight") // "insight" | "rule" | "warning"
  createdAt DateTime @default(now())

  ad        Ad?      @relation(fields: [adId], references: [id], onDelete: SetNull)
  adId      String?

  // Para búsqueda por tags
  angleType     String?  // Copiado del ad para filtrar
  angleDetail   String?
  awareness     String?
  format        String?
  result        String?  // winner/loser

  // Evaluación por elementos (copiado del ad)
  hookResult    String?
  hookNote      String?
  avatarResult  String?
  avatarNote    String?
  scriptResult  String?
  scriptNote    String?
  ctaResult     String?
  ctaNote       String?
  visualResult  String?
  visualNote    String?
  audioResult   String?
  audioNote     String?

  // Etiquetas (copiado del ad)
  failReasons      String?
  successFactors   String?
}

model Settings {
  id              String  @id @default("default")
  defaultLockDays Int     @default(10)
  defaultBudget   Float   @default(50)
}

// === MÓDULO DE RESEARCH ===

model Avatar {
  id            String         @id @default(cuid())
  name          String         // Ej: "Madres primerizas estresadas"
  description   String?        // Descripción general del avatar

  // Luchas diarias específicas (no genérico)
  painPoints    String         // JSON array de pain points específicos
  // Ej: ["Le da vergüenza ir a la piscina con sus hijos", "Se despierta a las 3am por ansiedad"]

  // Deseos y aspiraciones
  desires       String         // JSON array de deseos específicos
  // Ej: ["Quiere sentirse cómoda en su cuerpo", "Quiere tener energía para jugar con sus hijos"]

  // Objeciones comunes
  objections    String?        // JSON array de objeciones
  // Ej: ["No tengo tiempo", "Ya probé todo y nada funciona"]

  // Estilo de contenido orgánico que consume
  organicStyle  String?        // Qué tipo de contenido ve cuando NO ve ads
  // Ej: "TikToks de chicas hablando a cámara 3min, videos de transformación, testimonios raw"

  // Lenguaje que usa (para copy)
  language      String?        // Frases, palabras, expresiones que usa este avatar

  // Demografía básica (opcional)
  ageRange      String?        // Ej: "25-40"
  gender        String?        // Ej: "female", "male", "all"
  location      String?        // Ej: "LATAM", "España", "US Hispanic"

  // Relaciones
  research      ResearchItem[]
  ads           Ad[]
  nativeContent AvatarContent[]  // Contenido que este avatar consume
  subAvatars    SubAvatar[]      // Clusters de momento/estado
  insights      InsightAvatar[]  // Insights vinculados
  scoutSessions ScoutSession[]   // Sesiones de TikTok Scout
  tiktokSessions TikTokScanSession[]
  tiktokComments TikTokComment[]
  tiktokVideos   TikTokVideo[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// Sub-Avatar: Cluster de momento/estado (pain + deseo + trigger + objeción + awareness)
// La voz es la misma (Avatar) pero cambia el motor
model SubAvatar {
  id          String   @id @default(cuid())
  name        String   // Ej: "Después del pediatra", "Lunes por la mañana"

  // El cluster que define el momento/estado
  painPoint   String   // El dolor específico en este momento
  desire      String   // Lo que quiere lograr
  trigger     String?  // "Hoy pasó Z" - el detonante
  objection   String?  // La objeción principal en este estado
  awareness   String   @default("unaware") // Nivel de conciencia

  // Notas adicionales
  notes       String?  // Contexto o notas sobre este sub-avatar

  // Conexión con Avatar padre
  avatarId    String
  avatar      Avatar   @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  // Ads que usan este sub-avatar
  ads         Ad[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Contenido nativo que consume el avatar (para hacer ads nativos)
model AvatarContent {
  id          String   @id @default(cuid())

  // Media
  mediaUrl    String   // URL del video/imagen guardado
  mediaType   String   @default("video") // "video" | "image"
  thumbnailUrl String? // Thumbnail para preview

  // Información del contenido
  title       String?  // Título descriptivo
  sourceUrl   String?  // URL original (TikTok, YouTube, etc.)
  platform    String?  // "tiktok" | "youtube" | "instagram" | "reels"
  creator     String?  // @handle del creador original

  // Análisis del estilo
  style       String?  // Estilo del contenido: "talking_head", "vlog", "tutorial", etc.
  duration    String?  // Duración aproximada
  whatWorks   String?  // ¿Por qué este avatar consume este contenido?
  notes       String?  // Notas adicionales

  // Tags para filtrar
  tags        String?  // JSON array: ["relatable", "funny", "emotional"]

  // Conexión con avatar
  avatarId    String
  avatar      Avatar   @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model ResearchItem {
  id          String   @id @default(cuid())

  // Fuente del hallazgo
  source      String   // "Reddit", "TikTok Comments", "Facebook Group", "Amazon Review", "YouTube Comments", "Twitter"
  url         String?  // URL de donde se sacó

  // El contenido/quote directo
  content     String   // Ej: "Me despierto a las 3am por sudores fríos y mi esposo ni se entera"

  // Categorización
  category    String   // "pain_point", "desire", "objection", "language", "insight"

  // Contexto adicional
  context     String?  // Contexto de dónde/cómo se encontró

  // Etiquetas para búsqueda
  tags        String?  // JSON array de tags: ["sueño", "menopausia", "relación"]

  // Conexión con avatar
  avatarId    String?
  avatar      Avatar?  @relation(fields: [avatarId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
}

// === MÓDULO DE INSIGHTS (Lienzo libre) ===

model Insight {
  id          String   @id @default(cuid())
  title       String   // Título del documento
  content     String   @default("") // Contenido en JSON (Tiptap)

  // Vinculación opcional con avatars
  avatars     InsightAvatar[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Tabla de relación muchos a muchos entre Insight y Avatar
model InsightAvatar {
  id        String   @id @default(cuid())

  insightId String
  insight   Insight  @relation(fields: [insightId], references: [id], onDelete: Cascade)

  avatarId  String
  avatar    Avatar   @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([insightId, avatarId])
}

// === MÓDULO DE COMPETIDORES (Swipe File) ===

model Competitor {
  id          String   @id @default(cuid())
  name        String   // Nombre de la marca/competidor
  description String?  // Descripción del competidor
  website     String?  // Sitio web
  tiktok      String?  // @handle de TikTok
  instagram   String?  // @handle de Instagram
  facebook    String?  // Página de Facebook
  notes       String?  // Notas generales sobre el competidor

  // Relaciones
  ads         CompetitorAd[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompetitorAd {
  id          String   @id @default(cuid())

  // Media
  mediaUrl    String   // URL del video/imagen guardado
  mediaType   String   @default("video") // "video" | "image" | "carousel"
  thumbnailUrl String? // Thumbnail para preview

  // Información del ad
  title       String?  // Título descriptivo
  sourceUrl   String?  // URL original donde se encontró
  platform    String?  // "tiktok" | "facebook" | "instagram" | "youtube"

  // Análisis
  hook        String?  // Hook que usan
  angle       String?  // Ángulo que usan
  cta         String?  // CTA que usan
  whatWorks   String?  // ¿Qué funciona de este ad?
  notes       String?  // Notas adicionales

  // Tags para filtrar
  tags        String?  // JSON array: ["ugc", "testimonial", "offer"]

  // Conexión con competidor
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

// === MÓDULO DE TIKTOK SCOUT ===

model ScoutSession {
  id            String         @id @default(cuid())
  status        String         @default("running") // "running" | "completed" | "failed"
  query         String         // Qué se buscó
  context       String?        // Contexto adicional del usuario
  totalFindings Int            @default(0)

  // Conexión con Avatar
  avatarId      String
  avatar        Avatar         @relation(fields: [avatarId], references: [id], onDelete: Cascade)

  // Hallazgos de esta sesión
  findings      ScoutFinding[]

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model ScoutFinding {
  id              String   @id @default(cuid())
  type            String   // "video" | "comment" | "trend" | "creator"
  content         String   // Texto/descripción del hallazgo
  sourceUrl       String?  // URL de TikTok
  creator         String?  // @handle del creador
  engagement      String?  // JSON: { likes, comments, shares, views }
  relevance       String   @default("medium") // "high" | "medium" | "low"
  relevanceReason String   // Por qué es relevante para el avatar
  category        String   // "pain_point" | "desire" | "objection" | "language" | "trend" | "content_idea"
  thumbnailUrl    String?
  savedToResearch Boolean  @default(false)

  // Conexión con sesión
  sessionId       String
  session         ScoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt       DateTime @default(now())
}

// === MÓDULO DE TIKTOK CHROME SCRAPING ===

model TikTokScanSession {
  id          String   @id @default(cuid())
  avatarId    String?
  avatar      Avatar?  @relation(fields: [avatarId], references: [id])
  query       String?
  scanType    String   // comments, feed, search, profile
  sourceUrl   String
  status      String   @default("pending") // pending, scanning, classifying, completed, failed
  totalItems  Int      @default(0)
  summary     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  comments    TikTokComment[]
  videos      TikTokVideo[]
}

model TikTokComment {
  id              String   @id @default(cuid())
  sessionId       String
  session         TikTokScanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  videoUrl        String?
  username        String
  commentText     String
  likes           Int      @default(0)
  timestamp       String?
  replyTo         String?  // parent comment username if it's a reply

  // AI classification
  category        String?  // pain_point, desire, objection, language, neutral
  sentiment       String?  // positive, negative, neutral
  relevanceScore  Int?     // 0-100

  // Research integration
  savedToResearch Boolean  @default(false)
  avatarId        String?
  avatar          Avatar?  @relation(fields: [avatarId], references: [id])

  createdAt       DateTime @default(now())
}

model TikTokVideo {
  id              String   @id @default(cuid())
  sessionId       String
  session         TikTokScanSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  videoUrl        String
  description     String?
  hashtags        String?  // JSON array
  creator         String?
  views           Int?
  likes           Int?
  shares          Int?
  commentsCount   Int?
  thumbnailUrl    String?
  musicTitle      String?

  // AI classification
  category        String?  // pain_point, desire, objection, language, trend, content_idea
  relevanceScore  Int?

  // Research integration
  savedToResearch Boolean  @default(false)
  avatarId        String?
  avatar          Avatar?  @relation(fields: [avatarId], references: [id])

  createdAt       DateTime @default(now())
}

// === MÓDULO DE SEGUIMIENTO DE RENDIMIENTO ===

model DailyMetric {
  id        String   @id @default(cuid())
  date      DateTime // Día calendario de esta entrada

  spend                  Float  @default(0)
  impressions            Int    @default(0)
  clicks                 Int    @default(0)
  purchases              Int    @default(0)
  revenue                Float  @default(0)
  videoViewThreeSeconds  Int    @default(0)
  videoViewThruplay      Int    @default(0)

  adId      String
  ad        Ad       @relation(fields: [adId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([adId, date])
  @@index([date])
  @@index([adId])
}
